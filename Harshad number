import java.util.*;
import java.lang.*;
import java.io.*;

class java_basic
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc= new Scanner(System.in);
		int n= sc.nextInt();
		int t=n;
		int sum=0;
		while(n!=0)
		{
		    int d=n%10;
		    sum+=d;
		    n/=10;
		}
		if(t%sum==0)
		    System.out.println("Harshad Number");
		else
		    System.out.println("Not a Harshad Number");
	}
}
