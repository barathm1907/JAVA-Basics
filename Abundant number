import java.util.*;
import java.lang.*;
import java.io.*;

class java_basic
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc= new Scanner(System.in);
        System.out.println("Enter the number : "); //get the input
        int n=sc.nextInt();
        if(isAbundant(n))
            System.out.println("The number is an abundant number");
        else
            System.out.println("The number is not an abundant number");
        
	}
    static boolean isAbundant(int n)
    {
        int sum=0;      
        for(int i=1;i<n;i++)
        {
            if(n%i==0)
                sum+=i;
        }
        return sum>n; // if the sum of the proper divisors of a number is greater than the number, then the number is an abundant number
}
}