import java.util.*;
import java.lang.*;
import java.io.*;

class java_basic
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc= new Scanner(System.in);
        System.out.println("Enter the number : "); //get the input
        int n=sc.nextInt();
        int a=0,b=1,c;
        System.out.print(a+" "+b+" ");
        for(int i=2;i<n;i++)
        {
            c=a+b;
            System.out.print(c+" ");
            a=b;
            b=c;
        }
	}
}
