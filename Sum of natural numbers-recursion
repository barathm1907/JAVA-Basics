import java.util.*;
import java.lang.*;
import java.io.*;

class java_basic
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc=new Scanner(System.in);
		int sum=0;
		System.out.println("Enter the number : "); //get the input
		int n=sc.nextInt();
		System.out.print("The sum upto "+n+" is : ");  
		System.out.println(natural_num_sum(n,sum));   //call the function and print the output
	}
	static int natural_num_sum(int n,int sum)
	{
	    if(n==0)
	    {
	        return sum;
	    }
	    return natural_num_sum(n-1,sum+n);
	}
}
