import java.util.*;
import java.lang.*;
import java.io.*;

class java_basic
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc= new Scanner(System.in);
        System.out.println("Enter the number : "); //get the input
        int n=sc.nextInt();
        System.out.print("Divisors of the number are : ");
        for(int i=1;i*i<=n;i++) { 
            if(n%i==0) { 
                if(i*i==n) // if the number is a perfect square, we only print the divisor once
                System.out.print(i+" "); 
                else 
                    System.out.print(i+" "); 
                    System.out.print(n/i+" "); // print the divisor
            }
        }
	}
}
