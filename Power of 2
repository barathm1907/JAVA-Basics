import java.util.*;
import java.lang.*;
import java.io.*;

class java_basic
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc= new Scanner(System.in);
		int n=sc.nextInt();
        if(n>0&&(n&(n-1))==0) // a number is a power of 2 if it is greater than 0 and the bitwise AND of the number and the number minus 1 is 0, which means that the number has only one bit set in its binary representation
            System.out.println("Power of 2");
        else
            System.out.println("Not a Power of 2");
	}
}
