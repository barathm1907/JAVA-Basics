import java.util.*;
import java.lang.*;
import java.io.*;

class java_basic {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int rev=0;
        while(n!=0) {
            rev=rev*10+(n%10); // the reverse of a number is the last digit of the number plus the reverse of the number without the last digit multiplied by 10
            n/=10; // to remove the last digit of the number, we divide the number by 10 and take the integer part of the result, which is equivalent to removing the last digit of the number
        }
        System.out.println(rev);
    }
}